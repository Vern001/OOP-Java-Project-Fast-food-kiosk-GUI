<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<VBox alignment="CENTER" spacing="35.0" prefHeight="600.0" prefWidth="800.0"
      stylesheets="@../css/main.css"
      styleClass="welcome-root"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.fastfood.controller.MainMenuController">

    <Label text="Welcome"
           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2B2B2B;"/>

    <ImageView fx:id="brandLogo"
               fitWidth="360.0"
               preserveRatio="true">
        <image>
            <Image url="@../images/splash.png"/>
        </image>
    </ImageView>

    <Button text="Tap to Start Order"
            prefWidth="220.0"
            prefHeight="50.0"
            styleClass="start-order-btn"
            onAction="#handleStartOrder"/>

</VBox>