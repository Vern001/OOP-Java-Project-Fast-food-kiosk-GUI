<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox alignment="CENTER" spacing="40.0" prefHeight="600.0" prefWidth="800.0"
      stylesheets="@../css/main.css"
      styleClass="welcome-root"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.fastfood.controller.PaymentController">

    <VBox alignment="CENTER" spacing="10.0">
        <Label text="Select Payment Method" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2B2B2B;"/>
        <Label fx:id="totalAmountLabel" text="Amount Due: $0.00" style="-fx-font-size: 18px; -fx-text-fill: #666666;"/>
    </VBox>

    <HBox alignment="CENTER" spacing="30.0">
        <Button text="💳 Credit / Debit" prefWidth="180.0" prefHeight="120.0"
                styleClass="payment-option-btn" onAction="#handleCardPayment"/>
        <Button text="💵 Cash at Counter" prefWidth="180.0" prefHeight="120.0"
                styleClass="payment-option-btn" onAction="#handleCashPayment"/>
        <Button text="📱 Mobile Wallet" prefWidth="180.0" prefHeight="120.0"
                styleClass="payment-option-btn" onAction="#handleMobilePayment"/>
    </HBox>

    <HBox alignment="CENTER" spacing="20.0">
        <Button text="Back to Cart" prefWidth="140.0" prefHeight="40.0"
                styleClass="secondary-btn" onAction="#handleBackToCart"/>
    </HBox>

</VBox>